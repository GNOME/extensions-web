msgid "Password reset"
msgstr "تصفير كلمة السر"

#: sweettooth/auth/templates/registration/password_reset_form.html:8 extensions-web-domain-django:1
msgid "Forgot your password? Enter your e-mail address below, and we’ll e-mail instructions for setting a new one."
msgstr "أنسيت كلمة سرك؟ أدخل عنوان بريدك الإلكتروني أدناه، وسنرسل لك التعليمات لتعيين كلمة سر جديدة."

#: sweettooth/auth/views.py:104 extensions-web-domain-django:1
msgid "Your email address updated successfully"
msgstr "حُدِّث عنوان بريدك الإلكتروني بنجاح"

