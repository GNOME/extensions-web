msgid "Reset your password"
msgstr "صفِّر كلمة سرك"

#: sweettooth/auth/templates/registration/password_reset_confirm.html:15 extensions-web-domain-django:1
msgid "The token for the password reset is incorrect. Please check your link and try again."
msgstr "أمارة إعادة ضبط كلمة السر غير صحيحة. تحقق من الوصلة وأعِد المحاولة."

