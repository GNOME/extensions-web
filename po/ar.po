#. datetime object.
#. It's a date-time after which account will be deleted.
#: sweettooth/auth/templates/profile/settings.html:51 extensions-web-domain-django:1
#, python-format
msgid "Your account is scheduled for removal after %(schedule_delete_after)s"
msgstr "حسابك مجدول للإزالة بعد %(schedule_delete_after)s"

