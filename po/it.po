"Extensions distributed via this website are subject to the <a "
"href=\"%(url)s\">Code of Conduct</a>."
msgstr ""
"Le estensioni distribuite tramite questo sito sono soggette al <a "
"href=\"%(url)s\">codice di condotta</a>."

#: sweettooth/extensions/templates/extensions/upload.html:39
#: extensions-web-domain-django:1
#, python-format
msgid ""
"Extensions that violate the <a href=\"%(url)s\">Code of Conduct</a> will be "
"removed from this website."
msgstr ""
"Le estensioni che violano il <a href=\"%(url)s\">codice di condotta</a> "
"verranno rimosse dal sito."

