#: sweettooth/auth/forms.py:123 extensions-web-domain-django:1
msgid "You cannot change your email more than once every 7 days"
msgstr "Non è possibile cambiare l'email più di una volta ogni 7 giorni"

#: sweettooth/auth/forms.py:157 extensions-web-domain-django:1
msgid "Your display name contains forbidden words"
msgstr "Il nome visualizzato contiene parole proibite"

#: sweettooth/auth/forms.py:201 extensions-web-domain-django:1
msgid "Delete my account"
msgstr "Elimina account"

#: sweettooth/auth/forms.py:202 extensions-web-domain-django:1
msgid "Your account will be deleted in 7 days"
msgstr "L'account verrà eliminato tra 7 giorni"

#: sweettooth/auth/forms.py:204 extensions-web-domain-django:1
msgid "No"
msgstr "No"

#: sweettooth/auth/forms.py:204 extensions-web-domain-django:1
msgid "Yes"
msgstr "Sì"

#: sweettooth/auth/forms.py:208 extensions-web-domain-django:1
msgid "Current password"
msgstr "Password attuale"

